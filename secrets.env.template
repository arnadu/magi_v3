# MAGI V3 — secrets template
# Copy to secrets.env, fill in values, then run: bash scripts/bootstrap.sh
# secrets.env is gitignored and must never be committed.

# ── Core (required) ───────────────────────────────────────────────────────────

ANTHROPIC_API_KEY=
MONGODB_URI=

# Control plane operator password — generate with: openssl rand -hex 32
CONTROL_API_KEY=

# Signing key for per-mission MonitorServer tokens — generate with: openssl rand -hex 32
# Control plane only; never forwarded to execution plane machines.
MONITOR_SIGNING_KEY=

# ── Search and browsing (optional) ───────────────────────────────────────────

BRAVE_SEARCH_API_KEY=

# Alternative vision / BrowseWeb model provider
OPENROUTER_API_KEY=

# ── Firebase Auth ─────────────────────────────────────────────────────────────
# Server-side: Firebase Admin SDK (service account key JSON, minified to one line)
# Download from Firebase console → Project Settings → Service accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_KEY=

# Client-side: Firebase JS SDK config (public values — safe to store as Fly secrets)
# Find in Firebase console → Project Settings → General → Your apps → Web app → Config
FIREBASE_CLIENT_API_KEY=
FIREBASE_CLIENT_AUTH_DOMAIN=
FIREBASE_CLIENT_PROJECT_ID=

# ── Data API keys (.env.data-keys equivalent) ─────────────────────────────────
# Forwarded to background jobs only — never to agent tool subprocesses.

FRED_API_KEY=
FMP_API_KEY=
NEWSAPIORG_API_KEY=
