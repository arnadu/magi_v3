      "schedule": "daily",
      "output_dir": "news/central_bank_gold_gdelt",
      "_note": "Central bank demand — key structural force for gold"
    },
    {
      "id": "news/fed_policy_gdelt",
      "adapter": "gdelt",
      "params": { "query": "Federal Reserve monetary policy real interest rates", "max_records": 20 },
      "schedule": "daily",
