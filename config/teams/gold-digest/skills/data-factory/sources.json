    },
    {
      "id": "news/gold_market_gdelt",
      "adapter": "gdelt",
      "params": { "query": "gold market price XAU precious metals", "max_records": 30 },
      "schedule": "daily",
      "output_dir": "news/gold_market_gdelt",
      "_note": "No API key required. Free public endpoint."
    },
    {
      "id": "news/central_bank_gold_gdelt",
      "adapter": "gdelt",
