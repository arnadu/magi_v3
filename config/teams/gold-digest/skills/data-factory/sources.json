  "news": [
    {
      "id": "news/gold_market_newsapi",
      "adapter": "newsapi",
      "params": { "q": "gold XAU precious metals price", "language": "en" },
      "schedule": "daily",
      "output_dir": "news/gold_market_newsapi",
      "_note": "Requires NEWSAPIORG_API_KEY"
    },
    {
      "id": "news/fed_policy_newsapi",
      "adapter": "newsapi",
