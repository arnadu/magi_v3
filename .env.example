ANTHROPIC_API_KEY=sk-ant-...
# OPENROUTER_API_KEY=sk-or-...  # enables OpenRouter models (DeepSeek, Mistral, etc.)
# MONGODB_URI=mongodb://localhost:27017
# BRAVE_SEARCH_API_KEY=BSA...   # enables SearchWeb tool (free tier: 2000 req/month)

# MODEL=deepseek/deepseek-v3.2               # override main agent model (default: claude-sonnet-4-6)
# VISION_MODEL=mistralai/ministral-14b-2512  # override vision model (default: claude-haiku-4-5-20251001)
