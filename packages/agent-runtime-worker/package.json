{
	"name": "@magi/agent-runtime-worker",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"main": "./dist/index.js",
	"scripts": {
		"build": "tsc -p tsconfig.json && cp -rT public dist/public",
		"cli": "node dist/cli.js",
		"daemon": "node --import ./dist/node-polyfill.js dist/daemon.js",
		"cli:post": "node dist/cli-post.js",
		"cli:tail": "node dist/cli-tail.js",
		"cli:reset": "node dist/cli-reset.js",
		"cli:usage": "node dist/cli-usage.js",
		"cli:stop": "node dist/cli-stop.js",
		"install:browsers": "playwright install chromium"
	},
	"dependencies": {
		"@browserbasehq/stagehand": "^3.0.0",
		"cron-parser": "^4.9.0",
		"@magi/agent-config": "*",
		"@mariozechner/pi-ai": "file:../../refs/pi-mono/packages/ai",
		"@mozilla/readability": "^0.6.0",
		"@sinclair/typebox": "^0.34.41",
		"@types/jsdom": "^27.0.0",
		"execa": "^9.6.1",
		"jsdom": "^26.1.0",
		"mongodb": "^6.0.0",
		"mupdf": "^1.27.0",
		"node-cron": "^3.0.0",
		"playwright-core": "^1.50.0",
		"yaml": "^2.0.0",
		"zod": "^3.22.0"
	},
	"devDependencies": {
		"@types/node-cron": "^3.0.11"
	}
}
