# Secrets — must never enter any image layer
.env
.env.*
secrets.env
secrets.env.*
**/.env
**/.env.*

# Dev noise
**/node_modules
**/dist
.git
.github
docs
*.md
!packages/skills/**/*.md
!config/**/*.md
!packages/agent-runtime-worker/Dockerfile
!MAGI_V3_SPEC.md

# Local dev mission workdirs — Playwright cache, agent output, logs.
# These are never needed in any image layer.
packages/agent-runtime-worker/missions/
packages/agent-runtime-worker/home/
packages/agent-runtime-worker/daemon.log
packages/agent-runtime-worker/*.log
# Windows UNC-path garbage dirs that Playwright creates via WSL2 (names start with \).
packages/agent-runtime-worker/\\*
